#include <WiFi.h>
#include <PubSubClient.h>

// ---------------- WIFI & ThingsBoard ----------------
#define WIFI_SSID "Alexahome"
#define WIFI_PASSWORD "hngzhowxiantan"
#define TOKEN "YOUR_THINGSBOARD_DEVICE_TOKEN" // Replace with your device token

WiFiClient wifiClient;
PubSubClient client(wifiClient);
char mqttBroker[] = "demo.thingsboard.io"; // ThingsBoard server
char topic[] = "v1/devices/me/telemetry";

// ---------------- ECG Setup ----------------
#define ECG_PIN 34
#define SAMPLE_INTERVAL 4  // ms (~250Hz)
#define BATCH_SIZE 20      // Number of samples per MQTT message

float ecgBuffer[BATCH_SIZE];
uint8_t sampleIndex = 0;
unsigned long lastSampleTime = 0;

// ---------------- Functions ----------------
void reconnect() {
  while (!client.connected()) {
    Serial.print("Connecting to ThingsBoard...");
    if (client.connect("ESP32_ECG", TOKEN, "")) {
      Serial.println("Connected!");
    } else {
      Serial.print("Failed rc=");
      Serial.print(client.state());
      Serial.println(", retrying in 2s...");
      delay(2000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(ECG_PIN, INPUT);

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("Connecting to WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    Serial.print(".");
    delay(500);
  }
  Serial.println("\nWiFi Connected!");
  Serial.print("IP: "); Serial.println(WiFi.localIP());

  client.setServer(mqttBroker, 1883);
}

// ---------------- Main Loop ----------------
void loop() {
  if (!client.connected()) reconnect();
  client.loop();

  unsigned long now = millis();
  if (now - lastSampleTime >= SAMPLE_INTERVAL) {
    lastSampleTime = now;

    // Read ECG analog value and convert to voltage
    int raw = analogRead(ECG_PIN);
    float voltage = raw * (3.3 / 4095.0);
    ecgBuffer[sampleIndex++] = voltage;

    // When buffer is full, send it as JSON array
    if (sampleIndex >= BATCH_SIZE) {
      char payload[200];
      String json = "{\"ecg\":[";
      for (uint8_t i = 0; i < BATCH_SIZE; i++) {
        json += String(ecgBuffer[i], 3); // 3 decimal places
        if (i < BATCH_SIZE - 1) json += ",";
      }
      json += "]}";
      json.toCharArray(payload, json.length() + 1);

      client.publish(topic, payload);
      Serial.print("Sent ECG batch: ");
      Serial.println(json);

      sampleIndex = 0; // Reset buffer
    }
  }
}
